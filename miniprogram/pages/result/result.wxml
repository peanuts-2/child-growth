<view class="container">
  <!-- 基本信息 -->
  <view class="basic-info">
    <view class="info-tag">{{result.basicInfo.gender}}</view>
    <view class="info-tag">{{result.basicInfo.age}}</view>
    <view class="info-tag">身高{{result.basicInfo.height}}cm</view>
    <view class="info-tag">体重{{result.basicInfo.weight}}kg</view>
  </view>

  <!-- 身高评估 -->
  <view class="result-card">
    <view class="result-title">身高评估</view>
    <view class="result-main">
      <view class="percentile">{{result.height.percentile}}</view>
      <view class="percentile-label">百分位</view>
    </view>
    <view class="result-detail">
      <view class="grade {{result.height.interpolated < 25 ? 'grade-low' : result.height.interpolated > 75 ? 'grade-high' : 'grade-normal'}}">
        {{result.height.grade}}
      </view>
      <view class="value-range">参考范围：{{result.height.referenceValues.p3}} - {{result.height.referenceValues.p97}} cm</view>
      <view class="value-range">中等：{{result.height.referenceValues.p25}} - {{result.height.referenceValues.p75}} cm</view>
    </view>
  </view>

  <!-- 体重评估 -->
  <view class="result-card">
    <view class="result-title">体重评估</view>
    <view class="result-main">
      <view class="percentile">{{result.weight.percentile}}</view>
      <view class="percentile-label">百分位</view>
    </view>
    <view class="result-detail">
      <view class="grade {{result.weight.interpolated < 25 ? 'grade-low' : result.weight.interpolated > 75 ? 'grade-high' : 'grade-normal'}}">
        {{result.weight.grade}}
      </view>
      <view class="value-range">参考范围：{{result.weight.referenceValues.p3}} - {{result.weight.referenceValues.p97}} kg</view>
      <view class="value-range">中等：{{result.weight.referenceValues.p25}} - {{result.weight.referenceValues.p75}} kg</view>
    </view>
  </view>

  <!-- BMI评估 -->
  <view class="result-card">
    <view class="result-title">BMI评估</view>
    <view class="result-main bmi">
      <view class="bmi-value">{{result.basicInfo.bmi}}</view>
      <view class="bmi-label">kg/m²</view>
    </view>
    <view class="result-detail">
      <view class="grade {{result.bmi.grade === '正常' ? 'grade-normal' : result.bmi.grade === '超重' || result.bmi.grade === '肥胖' ? 'grade-high' : 'grade-low'}}">
        {{result.bmi.grade}}
      </view>
      <view class="advice">{{result.bmi.advice}}</view>
    </view>
  </view>

  <!-- 血压评估 -->
  <view class="result-card bp-card" wx:if="{{result.bloodPressure}}">
    <view class="result-title">血压评估</view>
    <view class="bp-values">
      <view class="bp-item">
        <view class="bp-label">收缩压</view>
        <view class="bp-value {{result.bloodPressure.systolic.status === 'hypertension' ? 'bp-high' : result.bloodPressure.systolic.status === 'normalHigh' ? 'bp-warning' : ''}}">
          {{result.bloodPressure.systolic.value}}
        </view>
        <view class="bp-unit">mmHg</view>
      </view>
      <view class="bp-separator">/</view>
      <view class="bp-item">
        <view class="bp-label">舒张压</view>
        <view class="bp-value {{result.bloodPressure.diastolic.status === 'hypertension' ? 'bp-high' : result.bloodPressure.diastolic.status === 'normalHigh' ? 'bp-warning' : ''}}">
          {{result.bloodPressure.diastolic.value}}
        </view>
        <view class="bp-unit">mmHg</view>
      </view>
    </view>
    <view class="result-detail">
      <view class="grade {{result.bloodPressure.overallStatus === 'normal' ? 'grade-normal' : result.bloodPressure.overallStatus === 'normalHigh' ? 'grade-warning' : 'grade-low'}}">
        {{result.bloodPressure.statusText}}
      </view>
      <view class="advice">{{result.bloodPressure.advice}}</view>
    </view>
    <view class="bp-reference">
      <view class="ref-title">参考范围</view>
      <view class="ref-item">正常：收缩压 < {{result.bloodPressure.reference.systolic.normalHigh}} mmHg</view>
      <view class="ref-item">偏高：收缩压 ≥ {{result.bloodPressure.reference.systolic.hypertension}} mmHg</view>
    </view>
  </view>

  <!-- 百分位曲线图示 -->
  <view class="percentile-chart">
    <view class="chart-title">百分位示意图</view>
    <view class="chart-container">
      <!-- 身高 -->
      <view class="chart-item">
        <view class="chart-label">身高</view>
        <view class="chart-bar">
          <view class="bar-scale">
            <text>P3</text>
            <text>P25</text>
            <text>P50</text>
            <text>P75</text>
            <text>P97</text>
          </view>
          <view class="bar-track">
            <view class="bar-marker" style="left: {{heightPosition}}%;"></view>
          </view>
        </view>
      </view>
      <!-- 体重 -->
      <view class="chart-item">
        <view class="chart-label">体重</view>
        <view class="chart-bar">
          <view class="bar-track">
            <view class="bar-marker" style="left: {{weightPosition}}%;"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 评估说明 -->
  <view class="notes">
    <view class="notes-title">评估说明</view>
    <view class="notes-item">• P50（第50百分位）为同龄儿童的平均值</view>
    <view class="notes-item">• P3-P97之间属于正常范围</view>
    <view class="notes-item">• 本评估仅供参考，不能替代专业医疗诊断</view>
    <view class="notes-item">• 如有疑虑，请咨询儿科医生</view>
  </view>

  <!-- 重新评估按钮 -->
  <button class="btn-again" bindtap="onAgain">重新评估</button>
</view>

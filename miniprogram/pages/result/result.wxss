.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.basic-info {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.info-tag {
  padding: 8rpx 20rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.result-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.result-main {
  text-align: center;
  padding: 30rpx 0;
}

.percentile {
  font-size: 72rpx;
  font-weight: bold;
  color: #1890ff;
  line-height: 1;
}

.percentile-label {
  font-size: 28rpx;
  color: #999;
  margin-top: 8rpx;
}

.result-main.bmi {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.bmi-value {
  font-size: 64rpx;
  font-weight: bold;
  color: #1890ff;
}

.bmi-label {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
}

.result-detail {
  text-align: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.grade {
  display: inline-block;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.grade-normal {
  background: #f6ffed;
  color: #52c41a;
}

.grade-low {
  background: #fff1f0;
  color: #ff4d4f;
}

.grade-high {
  background: #fff7e6;
  color: #fa8c16;
}

.grade-warning {
  background: #fffbe6;
  color: #faad14;
}

.value-range {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.advice {
  font-size: 26rpx;
  color: #666;
  margin-top: 12rpx;
}

/* 血压卡片 */
.bp-card {
  background: linear-gradient(135deg, #fff 0%, #f0f7ff 100%);
}

.bp-values {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.bp-item {
  text-align: center;
}

.bp-label {
  font-size: 24rpx;
  color: #999;
}

.bp-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #52c41a;
  line-height: 1.2;
}

.bp-value.bp-warning {
  color: #faad14;
}

.bp-value.bp-high {
  color: #ff4d4f;
}

.bp-unit {
  font-size: 24rpx;
  color: #999;
}

.bp-separator {
  font-size: 48rpx;
  color: #ddd;
  margin: 0 20rpx;
}

.bp-reference {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.ref-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 8rpx;
}

.ref-item {
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
}

/* 百分位曲线图 */
.percentile-chart {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.chart-item {
  margin-bottom: 24rpx;
}

.chart-item:last-child {
  margin-bottom: 0;
}

.chart-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.bar-scale {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.bar-track {
  height: 24rpx;
  background: linear-gradient(to right, #52c41a 0%, #52c41a 25%, #1890ff 25%, #1890ff 50%, #1890ff 50%, #52c41a 50%, #52c41a 75%, #52c41a 75%, #52c41a 100%);
  border-radius: 12rpx;
  position: relative;
}

.bar-marker {
  position: absolute;
  top: -8rpx;
  width: 16rpx;
  height: 40rpx;
  background: #ff4d4f;
  border-radius: 8rpx;
  transform: translateX(-50%);
}

/* 评估说明 */
.notes {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.notes-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 16rpx;
}

.notes-item {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}

.btn-again {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #1890ff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: 2rpx solid #1890ff;
}

.btn-again::after {
  border: none;
}

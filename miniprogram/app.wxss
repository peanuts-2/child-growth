page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 30rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.btn-primary {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary::after {
  border: none;
}

.result-card {
  text-align: center;
  padding: 40rpx;
}

.result-value {
  font-size: 80rpx;
  font-weight: bold;
  color: #1890ff;
  margin: 20rpx 0;
}

.result-label {
  font-size: 28rpx;
  color: #666;
}

.grade-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin-top: 20rpx;
}

.grade-excellent { background: #e6f7ff; color: #1890ff; }
.grade-good { background: #f6ffed; color: #52c41a; }
.grade-normal { background: #fffbe6; color: #faad14; }
.grade-low { background: #fff1f0; color: #ff4d4f; }
